# --- DB ---
MSSQL_SA_PASSWORD=your_strong_password

# --- IDENTITY ---
IDENTITY_DB_CONNECTION=Server=identity-db;Database=CodeJudexIdentityDb;User Id=sa;Password=your_password;TrustServerCertificate=True
IDENTITY_JWT_SECRET=your_secret_key_min_32_chars
IDENTITY_JWT_ISSUER=CodeJudex.Identity.Service
IDENTITY_JWT_AUDIENCE=CodeJudex.Web.Client

# --- AUDIT ---
AUDIT_JWT_SECRET=your_secret_key_min_32_chars
AUDIT_JWT_ISSUER=CodeJudex.Identity.Service
AUDIT_JWT_AUDIENCE=CodeJudex.Web.Client